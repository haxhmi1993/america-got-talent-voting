# Database Configuration
DATABASE_URL=postgresql+asyncpg://voting_user:voting_pass@postgres:5432/voting_db

# Redis Configuration (optional - will fallback to in-memory if not set)
REDIS_URL=redis://redis:6379

# Security
FINGERPRINT_SALT=change-this-to-a-secure-random-string-in-production

# Rate Limiting
IP_RATE_LIMIT=5
IP_RATE_WINDOW=60

# Nonce TTL (seconds)
NONCE_TTL=300

# Escalation (set to true to enable CAPTCHA/SMS challenges)
ENABLE_ESCALATION=false

# Device Tracking (set to true for cross-browser tracking)
USE_COMPOSITE_DEVICE_TRACKING=true

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
